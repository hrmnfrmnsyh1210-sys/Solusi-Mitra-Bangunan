#--------------------------------------------------------------------
# Template .env untuk PRODUKSI (Hostinger)
# Salin isi ini ke file `.env` di server, lalu isi nilai yang sebenarnya.
# JANGAN commit file `.env` asli ke Git (sudah masuk .gitignore).
#--------------------------------------------------------------------

CI_ENVIRONMENT = production

app.baseURL = 'https://solusimitrabangunan.com/'
app.indexPage = ''
app.forceGlobalSecureRequests = true

#--------------------------------------------------------------------
# DATABASE (lihat hPanel -> Databases -> MySQL)
#--------------------------------------------------------------------
database.default.hostname = localhost
database.default.database = u299742649_mitrabangunan
database.default.username = u299742649_mitrabangunan
database.default.password = 'ISI_PASSWORD_DB_DISINI'
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306

#--------------------------------------------------------------------
# GOOGLE OAUTH (Customer Login)
# Authorized redirect URI di Google Console harus diubah ke:
# https://solusimitrabangunan.com/shop/auth/callback
#--------------------------------------------------------------------
GOOGLE_CLIENT_ID = ISI_CLIENT_ID
GOOGLE_CLIENT_SECRET = ISI_CLIENT_SECRET
